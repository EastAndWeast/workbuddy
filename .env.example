# ============================================================
# RWA 自动化配置模板
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# ============================================================

# --- WordPress ---
WP_URL=https://your-site.com/wp-json/wp/v2/posts
WP_XMLRPC_URL=https://your-site.com/xmlrpc.php
WP_USER=your_username
WP_PASS=your_application_password
WP_CATEGORY_ID=4

# --- 飞书 (Feishu / Lark) ---
FEISHU_APP_ID=cli_xxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret
FEISHU_AUDIT_USER_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxx

# --- 封面图生成 API (OpenClaw) ---
COVER_API_URL=https://openclaw-api.com/v1/images/generations
COVER_API_KEY=sk-your-api-key
